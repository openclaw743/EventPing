{
  "name": "eventping-backend",
  "version": "1.0.0",
  "description": "EventPing backend service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "psql $DATABASE_URL -f ../database/seeds/dev.sql"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.28.1",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2"
  }
}
