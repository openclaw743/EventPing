# Application
NODE_ENV=development
PORT=3000

# Database
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://eventping:eventping_dev@localhost:5432/eventping

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Frontend
FRONTEND_URL=http://localhost:5173

# Azure (used by CI/CD, not needed locally)
AZURE_ACR_LOGIN_SERVER=
AZURE_CONTAINER_APP_NAME=
AZURE_RESOURCE_GROUP=
